# Reproductor de radio en la barra inferior (desactivado por defecto)
# PUBLIC_SHOW_RADIO_PLAYER=true

SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxx
ADMIN_ALLOWED_EMAILS=admin@cliente.com

# Tablas SQL en /supabase/: news_admin_setup, site_cms_setup, denuncias_setup, registros_setup

OPENWEATHER_API_KEY=
EXCHANGE_RATE_API_KEY=
# Twelve Data / simbolos COLCAP: el ticker no muestra COLCAP por ahora (codigo retirable al reactivarlo)
TWELVE_DATA_KEY=
TWELVE_DATA_COLCAP_SYMBOL=COLCAP
# Para S&P en ticker (respaldo si FMP falla); SPY suele responder mejor en Twelve Data que ^GSPC
TWELVE_DATA_SP500_SYMBOL=SPY
# Opcional: Financial Modeling Prep (S&P 500 en ticker; COLCAP deshabilitado en frontend)
FMP_API_KEY=
FMP_COLCAP_SYMBOL=^COLCAP
FMP_SP500_SYMBOL=^GSPC
# Resend (https://resend.com): correo al equipo y acuse al ciudadano en /api/denuncias
RESEND_API_KEY=
# Dominio verificado en Resend, ej: "Radio News <noticias@tudominio.com>"
EMAIL_FROM=
# Donde llegan las alertas de denuncias y registros (Resend)
NOTIFICATION_EMAIL=

# Opcional: webhook JSON si no usas solo Supabase para denuncias
SUBMISSIONS_WEBHOOK_URL=
SUBMISSIONS_WEBHOOK_SECRET=
