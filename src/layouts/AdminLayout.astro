---
import '../styles/global.css';

interface Props {
  title: string;
  userEmail?: string;
}

const { title, userEmail } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#041d3d] text-white">
    <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-4 py-8 md:px-6">
      <header class="mb-8 flex flex-col gap-4 rounded-[28px] border border-white/10 bg-white/5 p-6 backdrop-blur-sm md:flex-row md:items-center md:justify-between">
        <div>
          <a href="/admin" class="text-xs uppercase tracking-[0.24em] text-white/60">Radio News Admin</a>
          <h1 class="mt-3 font-newsreader text-3xl text-white md:text-4xl">{title}</h1>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          {userEmail && <span class="text-sm text-white/70">{userEmail}</span>}
          <a href="/admin" class="rounded-full border border-white/15 px-4 py-2 text-sm text-white/85 transition-colors hover:bg-white/10">
            Noticias
          </a>
          <a href="/admin/flash" class="rounded-full border border-white/15 px-4 py-2 text-sm text-white/85 transition-colors hover:bg-white/10">
            Flash
          </a>
          <a href="/admin/publicidad" class="rounded-full border border-white/15 px-4 py-2 text-sm text-white/85 transition-colors hover:bg-white/10">
            Publicidad
          </a>
          <a href="/admin/denuncias" class="rounded-full border border-white/15 px-4 py-2 text-sm text-white/85 transition-colors hover:bg-white/10">
            Denuncias
          </a>
          <a href="/admin/registros" class="rounded-full border border-white/15 px-4 py-2 text-sm text-white/85 transition-colors hover:bg-white/10">
            Registros
          </a>
          <a href="/admin/noticias/nueva" class="rounded-full bg-[#a62b2b] px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-[#8f2424]">
            Nueva noticia
          </a>
          <form method="POST" action="/api/admin/logout">
            <button type="submit" class="rounded-full border border-white/15 px-4 py-2 text-sm text-white/85 transition-colors hover:bg-white/10">
              Salir
            </button>
          </form>
        </div>
      </header>

      <main class="flex-1">
        <slot />
      </main>
    </div>
  </body>
</html>
