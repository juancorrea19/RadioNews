---
const logoSrc = '/logo-radio-news.png';

const primaryLinks = [
  { href: '/#flash-informativo', label: 'Flash Informativo' },
  { href: '/#lo-ultimo', label: 'Lo ultimo' },
  { href: '/#judicial', label: 'Judicial' },
  { href: '/#actualidad', label: 'Actualidad' },
  { href: '/#internacional', label: 'Internacional' },
  { href: '/#nacion', label: 'Nacion' },
  { href: '/#deportes', label: 'Deportes' },
];

const dropdownLinks = [
  { href: '/#flash-informativo', label: 'Flash Informativo' },
  { href: '/#ultima-hora', label: 'Ultima hora' },
  { href: '/#lo-ultimo', label: 'Lo ultimo' },
  { href: '/#judicial', label: 'Judicial' },
  { href: '/#actualidad', label: 'Actualidad' },
  { href: '/#internacional', label: 'Internacional' },
  { href: '/#nacion', label: 'Nacion' },
  { href: '/#deportes', label: 'Deportes' },
  { href: '/#entretenimiento', label: 'Entretenimiento' },
  { href: '/#magazine-cultural', label: 'Magazine Cultural' },
];

const now = new Date();
const meses = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
const currentDate = `${meses[now.getMonth()]}.${now.getDate()}-${now.getFullYear()}`;
---

<header class="sticky top-0 z-50 w-full rounded-b-[20px] bg-smoke shadow-lg">
  <div class="mx-auto w-full max-w-[1440px] px-4 py-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-5 lg:grid-cols-[auto_1fr_auto] lg:items-center lg:gap-8">
      <div class="flex items-center justify-between gap-4 lg:justify-start">
        <a href="/" aria-label="Ir al inicio de Radio News Online">
          <img
            src={logoSrc}
            alt="Radio News Online Logo"
            class="h-20 w-20 cursor-pointer rounded-full object-cover shadow-md ring-2 ring-[#a62b2b]/20 transition-opacity hover:opacity-90 sm:h-24 sm:w-24 lg:h-[100px] lg:w-[100px]"
          />
        </a>

        <div class="relative">
          <button
            id="header-menu-button"
            type="button"
            class="flex h-12 w-12 items-center justify-center rounded-full border border-[#1a2332] bg-white/90 shadow-md transition-all hover:bg-white focus:outline-none focus:ring-2 focus:ring-[#a62b2b]/30"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="header-dropdown-menu"
          >
            <span class="sr-only">Abrir menu de categorias</span>
            <svg width="28" height="20" viewBox="0 0 41 27" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect y="0" width="41" height="3" rx="1.5" fill="#1a2332"></rect>
              <rect y="12" width="41" height="3" rx="1.5" fill="#1a2332"></rect>
              <rect y="24" width="41" height="3" rx="1.5" fill="#1a2332"></rect>
            </svg>
          </button>

          <div
            id="header-dropdown-menu"
            class="invisible absolute right-0 top-14 z-50 flex w-[min(240px,calc(100vw-2rem))] origin-top-right scale-95 flex-col rounded-lg bg-white py-2 opacity-0 shadow-2xl transition duration-150 ease-out lg:left-0 lg:right-auto lg:w-auto lg:min-w-[240px] lg:origin-top-left"
          >
            {dropdownLinks.map((link) => (
              <a
                href={link.href}
                class="px-5 py-2.5 text-base font-semibold text-[#1a2332] transition-colors hover:bg-[#a62b2b] hover:text-white"
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <div class="flex flex-col items-center gap-3">
        <div class="flex flex-col items-center gap-1">
          <h1 class="text-center font-newsreader text-2xl font-semibold tracking-wide text-[#1a2332] sm:text-3xl lg:text-[36px]">
            RADIO NEWS ONLINE
          </h1>
          <div class="h-px w-full max-w-[400px] bg-[#1a2332]"></div>
        </div>

        <nav class="hidden flex-wrap items-center justify-center gap-2 md:flex lg:gap-3" aria-label="Secciones principales">
          <span class="font-inter text-sm text-slate-600 lg:text-base">{currentDate}</span>
          {primaryLinks.map((link) => (
            <span class="contents">
              <div class="h-6 w-px bg-slate-400"></div>
              <a href={link.href} class="text-[#1a2332] transition-colors hover:text-[#a62b2b] lg:text-base text-md font-semibol font-newsreader hover:font-bold">
                {link.label}
              </a>
            </span>
          ))}
        </nav>
      </div>
      <div class="flex items-center justify-center gap-3 lg:justify-end">
        <button
          type="button"
          data-open-modal="denuncia-modal"
          class="group flex h-10 items-center gap-2 rounded-full bg-[#a62b2b] px-4 font-newsreader text-sm font-semibold text-white shadow-md transition-all hover:bg-[#8a2424] active:scale-95"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0"></path>
            <line x1="12" y1="9" x2="12" y2="13"></line>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
          <span class="hidden sm:inline">Denuncia aqui</span>
          <span class="sm:hidden">Denunciar</span>
        </button>

        <button
          type="button"
          data-open-modal="registro-modal"
          class="flex h-10 items-center gap-2 rounded-full border-2 border-[#1a2332] bg-transparent px-4 font-newsreader text-sm font-bold text-[#1a2332] transition-all hover:bg-[#1a2332] hover:text-white active:scale-95"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="8.5" cy="7" r="4"></circle>
            <line x1="20" y1="8" x2="20" y2="14"></line>
            <line x1="23" y1="11" x2="17" y2="11"></line>
          </svg>
          Registrarse
        </button>
      </div>
    </div>
  </div>
</header>

<div id="denuncia-modal" data-modal-root class="fixed inset-0 z-[120] hidden items-center justify-center bg-[#041d3d]/70 px-4 py-8 backdrop-blur-sm">
  <div data-modal-backdrop class="absolute inset-0"></div>
  <div class="relative z-10 w-full max-w-2xl overflow-hidden rounded-[30px] border border-white/10 bg-[#f2f2f2] text-[#1a2332] shadow-[0_30px_80px_rgba(0,0,0,0.35)]">
    <div class="border-b border-slate-200 bg-[linear-gradient(135deg,#ffffff,#f8ecec)] px-6 py-5 md:px-8">
      <div class="flex items-start justify-between gap-4">
        <div>
          <span class="rounded-full bg-[#a62b2b] px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-white">Radio News Online</span>
          <h2 class="mt-4 font-newsreader text-3xl text-[#1a2332]">Registrar denuncia</h2>
          <p class="mt-3 max-w-2xl font-newsreader text-base font-medium leading-relaxed text-[#1a2332] md:text-lg">
            Cuéntanos qué ocurrió, dónde y cómo contactarte. Si tienes pruebas, adjúntalas en el formulario. Al enviar, tu denuncia llega al equipo de redacción y recibirás confirmación en tu correo.
          </p>
        </div>
        <button type="button" data-close-modal class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 transition hover:border-[#a62b2b] hover:text-[#a62b2b]">x</button>
      </div>
    </div>

    <div class="max-h-[calc(100vh-180px)] overflow-y-auto px-6 py-6 md:px-8">
      <form data-async-form data-success-message="Tu denuncia fue enviada correctamente." action="/api/denuncias" method="POST" enctype="multipart/form-data" class="space-y-5">
        <div class="grid gap-4 md:grid-cols-2">
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Nombre completo</span>
            <input class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#a62b2b] focus:bg-white focus:ring-2 focus:ring-[#a62b2b]/15" type="text" name="nombre" required />
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Numero de contacto</span>
            <input class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#a62b2b] focus:bg-white focus:ring-2 focus:ring-[#a62b2b]/15" type="tel" name="numero" required />
          </label>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Correo electronico</span>
            <input class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#a62b2b] focus:bg-white focus:ring-2 focus:ring-[#a62b2b]/15" type="email" name="correo" required />
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Ubicacion</span>
            <input class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#a62b2b] focus:bg-white focus:ring-2 focus:ring-[#a62b2b]/15" type="text" name="ubicacion" required />
          </label>
        </div>

        <label class="flex flex-col gap-2">
          <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Descripcion de la denuncia</span>
          <textarea class="min-h-36 w-full resize-y rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#a62b2b] focus:bg-white focus:ring-2 focus:ring-[#a62b2b]/15" name="descripcion" required placeholder="Resume lo ocurrido, fechas, nombres o datos que ayuden a validar el caso."></textarea>
        </label>

        <label class="flex flex-col gap-2">
          <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Evidencia</span>
          <div class="rounded-2xl border border-dashed border-slate-400 bg-white px-4 py-4">
            <input class="block w-full text-base font-medium text-[#1a2332] file:mr-4 file:rounded-full file:border-0 file:bg-[#a62b2b] file:px-4 file:py-2.5 file:text-sm file:font-semibold file:text-white hover:file:bg-[#8a2424]" type="file" name="evidencia" accept=".jpg,.jpeg,.png,.pdf,.doc,.docx,.mp4,.mp3" />
            <p class="mt-3 text-sm font-medium leading-6 text-slate-700">Puedes adjuntar fotos, documentos, audio o video (máx. 8 MB). Tu evidencia se envía de forma segura junto con la denuncia.</p>
          </div>
        </label>

        <label class="flex items-start gap-3 rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base font-medium leading-relaxed text-[#1a2332]">
          <input type="checkbox" name="autorizaContacto" required class="mt-1 h-4 w-4 shrink-0 accent-[#a62b2b]" />
          <span>Autorizo a Radio News Online a contactarme para ampliar esta información si hace falta.</span>
        </label>

        <div data-form-feedback class="hidden rounded-2xl px-4 py-3 text-sm"></div>

        <div class="flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:justify-end">
          <button type="button" data-close-modal class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-600 transition hover:border-slate-400 hover:text-slate-900">Cancelar</button>
          <button type="submit" class="rounded-full bg-[#a62b2b] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#8a2424]">Enviar denuncia</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div id="registro-modal" data-modal-root class="fixed inset-0 z-[120] hidden items-center justify-center bg-[#041d3d]/70 px-4 py-8 backdrop-blur-sm">
  <div data-modal-backdrop class="absolute inset-0"></div>
  <div class="relative z-10 w-full max-w-2xl overflow-hidden rounded-[30px] border border-white/10 bg-[#f2f2f2] text-[#1a2332] shadow-[0_30px_80px_rgba(0,0,0,0.35)]">
    <div class="border-b border-slate-200 bg-[linear-gradient(135deg,#ffffff,#eef2f9)] px-6 py-5 md:px-8">
      <div class="flex items-start justify-between gap-4">
        <div>
          <span class="rounded-full bg-[#1a2332] px-3 py-1 text-[10px] uppercase tracking-[0.18em] text-white">Radio News Online</span>
          <h2 class="mt-4 font-newsreader text-3xl text-[#1a2332]">Registro de colaboradores</h2>
          <p class="mt-3 max-w-2xl font-newsreader text-base font-medium leading-relaxed text-[#1a2332] md:text-lg">
            Completa tus datos y dinos cómo te gustaría colaborar con Radio News Online. Al enviar el formulario recibirás un correo de confirmación y el equipo te contactará si hay una oportunidad acorde a tu perfil.
          </p>
        </div>
        <button type="button" data-close-modal class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 transition hover:border-[#1a2332] hover:text-[#1a2332]">x</button>
      </div>
    </div>

    <div class="max-h-[calc(100vh-180px)] overflow-y-auto px-6 py-6 md:px-8">
      <form data-async-form data-success-message="Tu registro fue enviado correctamente." action="/api/registros" method="POST" class="space-y-5">
        <div class="grid gap-4 md:grid-cols-2">
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Nombre completo</span>
            <input class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#1a2332] focus:bg-white focus:ring-2 focus:ring-[#1a2332]/15" type="text" name="nombre" required />
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Correo electronico</span>
            <input class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#1a2332] focus:bg-white focus:ring-2 focus:ring-[#1a2332]/15" type="email" name="correo" required />
          </label>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Telefono</span>
            <input class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#1a2332] focus:bg-white focus:ring-2 focus:ring-[#1a2332]/15" type="tel" name="telefono" required />
          </label>
          <label class="flex flex-col gap-2">
            <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Ciudad o ubicacion</span>
            <input class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#1a2332] focus:bg-white focus:ring-2 focus:ring-[#1a2332]/15" type="text" name="ubicacion" required />
          </label>
        </div>

        <label class="flex flex-col gap-2">
          <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Como deseas colaborar</span>
          <select class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#1a2332] focus:bg-white focus:ring-2 focus:ring-[#1a2332]/15" name="interes" required>
            <option value="lector">Quiero recibir informacion</option>
            <option value="fuente">Puedo compartir denuncias o datos</option>
            <option value="publicidad">Me interesa pautar publicidad</option>
            <option value="alianza">Quiero explorar una alianza</option>
          </select>
        </label>

        <label class="flex flex-col gap-2">
          <span class="text-xs font-bold uppercase tracking-[0.12em] text-[#1a2332] md:text-sm">Mensaje adicional</span>
          <textarea class="min-h-32 w-full resize-y rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base text-[#1a2332] placeholder:text-slate-500 outline-none transition focus:border-[#1a2332] focus:bg-white focus:ring-2 focus:ring-[#1a2332]/15" name="mensaje" placeholder="Cuentanos brevemente como te gustaria colaborar o que informacion quieres recibir."></textarea>
        </label>

        <label class="flex items-start gap-3 rounded-2xl border border-slate-300 bg-white px-4 py-3.5 text-base font-medium leading-relaxed text-[#1a2332]">
          <input type="checkbox" name="autorizaCorreo" required class="mt-1 h-4 w-4 shrink-0 accent-[#1a2332]" />
          <span>Acepto ser contactado por correo para recibir novedades, propuestas de colaboración o seguimiento.</span>
        </label>

        <div data-form-feedback class="hidden rounded-2xl px-4 py-3 text-sm"></div>

        <div class="flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:justify-end">
          <button type="button" data-close-modal class="rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-600 transition hover:border-slate-400 hover:text-slate-900">Cancelar</button>
          <button type="submit" class="rounded-full bg-[#1a2332] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#102033]">Enviar registro</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    if (window.__radioNewsHeaderInitialized) return;
    window.__radioNewsHeaderInitialized = true;

    const initHeaderInteractions = () => {
      const button = document.getElementById('header-menu-button');
      const menu = document.getElementById('header-dropdown-menu');

      if (button instanceof HTMLButtonElement && menu instanceof HTMLDivElement) {
        let closeTimer;

        const openMenu = () => {
          if (closeTimer !== undefined) {
            window.clearTimeout(closeTimer);
            closeTimer = undefined;
          }

          menu.classList.remove('invisible', 'scale-95', 'opacity-0');
          menu.classList.add('visible', 'scale-100', 'opacity-100');
          button.setAttribute('aria-expanded', 'true');
        };

        const closeMenu = () => {
          menu.classList.remove('visible', 'scale-100', 'opacity-100');
          menu.classList.add('invisible', 'scale-95', 'opacity-0');
          button.setAttribute('aria-expanded', 'false');
        };

        const scheduleClose = () => {
          closeTimer = window.setTimeout(closeMenu, 120);
        };

        button.addEventListener('click', () => {
          const expanded = button.getAttribute('aria-expanded') === 'true';
          if (expanded) {
            closeMenu();
          } else {
            openMenu();
          }
        });

        button.addEventListener('mouseenter', openMenu);
        button.addEventListener('focus', openMenu);
        button.addEventListener('mouseleave', scheduleClose);
        menu.addEventListener('mouseenter', openMenu);
        menu.addEventListener('mouseleave', scheduleClose);

        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Node)) return;
          if (!menu.contains(target) && !button.contains(target)) {
            closeMenu();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeMenu();
            button.blur();
          }
        });
      }

      const modalRoots = Array.from(document.querySelectorAll('[data-modal-root]'));
      const openButtons = Array.from(document.querySelectorAll('[data-open-modal]'));
      const closeButtons = Array.from(document.querySelectorAll('[data-close-modal]'));
      const forms = Array.from(document.querySelectorAll('[data-async-form]'));

      const openModal = (modalId) => {
        const modal = document.getElementById(modalId);
        if (!(modal instanceof HTMLDivElement)) return;

        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
      };

      const closeModal = (modal) => {
        modal.classList.remove('flex');
        modal.classList.add('hidden');
        document.body.style.overflow = '';

        const feedback = modal.querySelector('[data-form-feedback]');
        if (feedback instanceof HTMLDivElement) {
          feedback.className = 'hidden rounded-2xl px-4 py-3 text-sm';
          feedback.textContent = '';
        }
      };

      openButtons.forEach((buttonEl) => {
        if (!(buttonEl instanceof HTMLButtonElement)) return;

        buttonEl.addEventListener('click', () => {
          const modalId = buttonEl.dataset.openModal;
          if (modalId) {
            openModal(modalId);
          }
        });
      });

      closeButtons.forEach((buttonEl) => {
        if (!(buttonEl instanceof HTMLButtonElement)) return;

        buttonEl.addEventListener('click', () => {
          const modal = buttonEl.closest('[data-modal-root]');
          if (modal instanceof HTMLDivElement) {
            closeModal(modal);
          }
        });
      });

      modalRoots.forEach((modal) => {
        if (!(modal instanceof HTMLDivElement)) return;

        const backdrop = modal.querySelector('[data-modal-backdrop]');
        if (backdrop instanceof HTMLDivElement) {
          backdrop.addEventListener('click', () => closeModal(modal));
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;

        modalRoots.forEach((modal) => {
          if (modal instanceof HTMLDivElement && !modal.classList.contains('hidden')) {
            closeModal(modal);
          }
        });
      });

      forms.forEach((formEl) => {
        if (!(formEl instanceof HTMLFormElement)) return;

        formEl.addEventListener('submit', async (event) => {
          event.preventDefault();

          const submitButton = formEl.querySelector('button[type="submit"]');
          const feedback = formEl.querySelector('[data-form-feedback]');
          const modal = formEl.closest('[data-modal-root]');
          const successMessage = formEl.dataset.successMessage || 'Formulario enviado correctamente.';

          if (!(submitButton instanceof HTMLButtonElement) || !(feedback instanceof HTMLDivElement)) {
            return;
          }

          submitButton.disabled = true;
          const originalText = submitButton.textContent;
          submitButton.textContent = 'Enviando...';
          feedback.className = 'hidden rounded-2xl px-4 py-3 text-sm';
          feedback.textContent = '';

          try {
            const response = await fetch(formEl.action, {
              method: 'POST',
              body: new FormData(formEl),
            });

            const payload = await response.json().catch(() => ({}));

            if (!response.ok) {
              throw new Error(payload.message || 'No se pudo enviar el formulario.');
            }

            feedback.className = 'rounded-2xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700';
            feedback.textContent = payload.message || successMessage;
            formEl.reset();

            if (modal instanceof HTMLDivElement) {
              window.setTimeout(() => closeModal(modal), 1200);
            }
          } catch (error) {
            feedback.className = 'rounded-2xl bg-red-50 px-4 py-3 text-sm text-red-700';
            feedback.textContent = error instanceof Error ? error.message : 'Ocurrio un error inesperado.';
          } finally {
            submitButton.disabled = false;
            submitButton.textContent = originalText;
          }
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeaderInteractions, { once: true });
      return;
    }

    initHeaderInteractions();
  })();
</script>
