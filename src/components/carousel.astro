---
import type { FlashCarouselSlide } from "../lib/site-content";

interface Props {
  slides: FlashCarouselSlide[];
}

const { slides } = Astro.props;
---

{
  slides.length === 0 ? (
    <div class="relative z-10 mx-auto mt-6 max-w-7xl rounded-[2rem] border border-dashed border-white/20 bg-white/5 px-6 py-16 text-center backdrop-blur-sm">
      <p class="font-newsreader text-lg text-white md:text-xl">
        Pronto veras aqui el flash informativo. Publica diapositivas desde el panel de administracion.
      </p>
    </div>
  ) : (
    <div
      id="flash-carousel"
      class="relative z-10 mx-auto mt-6 flex w-full max-w-7xl items-stretch gap-2 px-4 md:items-center md:gap-4"
    >
      <button
        type="button"
        class="carousel-prev hidden shrink-0 items-center justify-center self-center rounded-full p-4 text-white transition-all hover:bg-white/10 lg:flex"
        aria-label="Anterior noticia"
      >
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M18 4L8 14L18 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>

      <div class="z-10 min-w-0 flex-1 px-0 md:px-2">
        <section class="w-full">
          <div class="mx-auto flex w-full flex-col">
            <div aria-roledescription="carrusel">
              <div
                class="carousel-track scrollbar-hide flex w-full snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth pb-40 pt-4 md:pb-32"
                tabindex="0"
              >
                {slides.map((slide, i) => (
                  <article
                    class="relative min-w-0 w-full shrink-0 snap-center snap-always basis-full"
                    aria-label={`Noticia ${i + 1} de ${slides.length}`}
                    data-slide-index={i}
                  >
                    <div class="group relative aspect-square w-full overflow-hidden rounded-[2rem] border-[4px] border-white/20 shadow-2xl sm:aspect-video md:aspect-[21/9] md:border-[6px]">
                      <img
                        src={slide.imagenUrl}
                        alt={slide.imagenAlt}
                        class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                        loading={i === 0 ? "eager" : "lazy"}
                        decoding="async"
                      />
                    </div>

                    <div class="absolute bottom-0 left-0 right-0 z-20 mx-auto flex w-[92%] translate-y-1/2 flex-col overflow-hidden rounded-2xl border border-white/40 bg-[#d2d6d9]/95 p-4 shadow-2xl backdrop-blur-md md:w-[85%] md:p-5">
                      <span class="mb-1 block font-newsreader text-lg font-extrabold text-[#a62b2b] md:text-xl">{slide.categoria}</span>

                      <h2 class="mb-2 line-clamp-2 font-newsreader text-xl font-bold leading-tight text-[#0d1218] sm:text-2xl md:text-3xl">
                        <a
                          href={slide.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-[#0d1218] transition-colors hover:text-[#a62b2b]"
                        >
                          {slide.titulo}
                        </a>
                      </h2>

                      <p class="mb-3 line-clamp-2 font-newsreader text-base font-medium leading-snug text-[#1a2332] md:text-lg md:leading-relaxed">
                        {slide.texto}
                      </p>

                      <div class="flex flex-wrap items-center justify-between gap-2 border-t border-slate-400/50 pt-3">
                        <p class="font-inter text-xs font-semibold text-[#1a2332] md:text-sm">{slide.fechaLinea}</p>
                        <a
                          href={slide.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex shrink-0 rounded-full bg-[#a62b2b] px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.12em] text-white transition-colors hover:bg-[#8f2424] md:px-4 md:py-2 md:text-xs"
                        >
                          Ver noticia completa
                        </a>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>

            <div class="mt-4 flex justify-center gap-2" role="tablist" aria-label="Indicadores del carrusel">
              {slides.map((_, i) => (
                <button
                  type="button"
                  class="carousel-dot h-2.5 w-2.5 cursor-pointer rounded-full bg-white/30 transition-colors hover:bg-white/50 data-[active=true]:bg-firebrick"
                  aria-label={`Ir a noticia ${i + 1}`}
                  aria-current={i === 0 ? "true" : "false"}
                  data-dot-index={i}
                />
              ))}
            </div>
          </div>
        </section>
      </div>

      <button
        type="button"
        class="carousel-next hidden shrink-0 items-center justify-center self-center rounded-full p-4 text-white transition-all hover:bg-white/10 lg:flex"
        aria-label="Siguiente noticia"
      >
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M10 4L20 14L10 24" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  )
}

{
  slides.length > 0 && (
    <script>
      import { initFlashCarousel } from "../scripts/flash-carousel.ts";

      initFlashCarousel();
      document.addEventListener("astro:page-load", initFlashCarousel);
    </script>
  )
}
