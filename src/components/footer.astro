---
import Background from '../assets/Background.svg';
---

<footer class="w-full bg-smoke mt-10 border-t border-white/20 shadow-[0_-10px_10px_-5px_rgba(255,255,255,0.4)] pb-0 relative z-1 mb-20">
  <div class="max-w-[1440px] mx-auto px-4 pt-10 pb-8">
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 items-start">
      
      <div class="flex flex-col items-center md:items-start space-y-4">
        <div class="flex flex-col items-center md:items-start">
          <img src={Background.src} alt="Radio News Online Logo" class="w-16 h-16 object-contain mb-2" />
          <h2 class="text-xl sm:text-2xl font-newsreader font-semibold text-[#1a2332] tracking-wider">
            RADIO NEWS ONLINE
          </h2>
          <p class="text-gray-600 italic font-newsreader text-base">“La noticia a un click”</p>
        </div>

        <div class="flex flex-col items-center md:items-start gap-3 pt-2">
          <span class="text-[#1a2332] font-semibold text-lg uppercase tracking-tight">Encuéntranos</span>
          <div class="flex items-center gap-4">
            <a href="https://www.instagram.com/radionews_online/" class="hover:scale-110 transition-transform flex items-center justify-center w-10 h-10 rounded-full bg-[#a62b2b] p-2.5 shadow-sm" aria-label="Instagram">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/instagram.svg" class="w-full h-full object-contain invert" alt="Instagram" />
            </a>
            <a href="https://www.facebook.com/radionewsonline/" class="hover:scale-110 transition-transform flex items-center justify-center w-10 h-10 rounded-full bg-[#a62b2b] p-2.5 shadow-sm" aria-label="Facebook">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/facebook.svg" class="w-full h-full object-contain invert" alt="Facebook" />
            </a>
            <a href="https://www.youtube.com/@radionewsonline" class="hover:scale-110 transition-transform flex items-center justify-center w-10 h-10 rounded-full bg-[#a62b2b] p-2.5 shadow-sm" aria-label="YouTube">
              <img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/youtube.svg" class="w-full h-full object-contain invert" alt="YouTube" />
            </a>
          </div>
        </div>
      </div>

      <div class="flex flex-col items-center justify-start h-full">
        <div class="flex flex-col items-center md:items-start gap-4">
            <span class="text-[#1a2332] font-semibold text-lg uppercase tracking-tight">Institucional</span>
            <ul class="space-y-3 text-[#1a2332] font-medium text-sm sm:text-base text-center md:text-left">
              <li>
                <a href="/quienes-somos" class="hover:text-[#a62b2b] transition-colors flex items-center gap-2">
                  <span class="text-[#a62b2b]">●</span> Quiénes somos
                </a>
              </li>
              <li>
                <a href="/valores" class="hover:text-[#a62b2b] transition-colors flex items-center gap-2">
                  <span class="text-[#a62b2b]">●</span> Valores
                </a>
              </li>
              <li>
                <a href="/politicas" class="hover:text-[#a62b2b] transition-colors flex items-center gap-2">
                  <span class="text-[#a62b2b]">●</span> Política de privacidad
                </a>
              </li>
            </ul>
        </div>
      </div>

      <div class="flex flex-col items-center md:items-end justify-start h-full">
        <div class="flex flex-col items-center md:items-start gap-4">
            <span class="text-[#1a2332] font-semibold text-lg uppercase tracking-tight">Contacto</span>
            <ul class="space-y-3 text-[#1a2332] font-medium text-sm sm:text-base">
              <li class="flex items-center gap-3">
                <span class="text-[#a62b2b]">●</span> 
                <span>contacto@radionewsonline.com</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="text-[#a62b2b]">●</span> 
                <span>+57 300 000 0000</span>
              </li>
              <li class="flex items-center gap-3">
                <span class="text-[#a62b2b]">●</span> 
                <span>Bogota D.C., Colombia</span>
              </li>
            </ul>
        </div>
      </div>

    </div>
  </div>

  <div class="w-full border-t border-gray-300 py-4 bg-white/40">
    <p class="text-center text-sm font-semibold text-[#1a2332] m-0">
      © 2026 Radio News Online. Todos los derechos reservados.
    </p>
  </div>
</footer>
