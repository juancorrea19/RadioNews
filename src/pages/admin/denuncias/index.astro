---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getAuthenticatedAdmin } from "../../../lib/server/admin-auth";
import { listDenunciasForAdmin } from "../../../lib/server/denuncias";
import { isSupabaseConfigured } from "../../../lib/server/supabase";

const session = await getAuthenticatedAdmin(Astro.cookies);

if (!session.user) {
  return Astro.redirect("/admin/login");
}

if (!isSupabaseConfigured()) {
  return Astro.redirect("/admin/login?error=config");
}

let denuncias: Awaited<ReturnType<typeof listDenunciasForAdmin>> = [];
try {
  denuncias = await listDenunciasForAdmin();
} catch {
  denuncias = [];
}
---

<AdminLayout title="Denuncias" userEmail={session.user.email ?? undefined}>
  <section class="rounded-[28px] border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
    <p class="mb-6 text-sm text-white/70">
      Listado de denuncias guardadas en Supabase. Los enlaces de evidencia son temporales (URL firmada).
    </p>

    {denuncias.length === 0 ? (
      <div class="rounded-[22px] border border-dashed border-white/15 bg-[#06172f] p-8 text-center text-white/75">
        Aun no hay denuncias registradas o la tabla no existe. Ejecuta <code class="text-white/90">supabase/denuncias_setup.sql</code> en el proyecto.
      </div>
    ) : (
      <div class="overflow-x-auto overflow-hidden rounded-[22px] border border-white/10">
        <table class="min-w-full divide-y divide-white/10 text-left text-sm">
          <thead class="bg-white/5 text-xs uppercase tracking-[0.18em] text-white/60">
            <tr>
              <th class="px-4 py-3">Fecha</th>
              <th class="px-4 py-3">Nombre</th>
              <th class="px-4 py-3">Correo</th>
              <th class="px-4 py-3">Ubicacion</th>
              <th class="px-4 py-3">Evidencia</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/10 bg-[#06172f]">
            {denuncias.map((d) => (
              <tr>
                <td class="whitespace-nowrap px-4 py-3 text-white/80">
                  {new Date(d.created_at).toLocaleString("es-CO")}
                </td>
                <td class="max-w-[140px] truncate px-4 py-3 text-white" title={d.nombre}>
                  {d.nombre}
                </td>
                <td class="max-w-[180px] truncate px-4 py-3 text-white/85" title={d.correo}>
                  {d.correo}
                </td>
                <td class="max-w-[120px] truncate px-4 py-3 text-white/75" title={d.ubicacion}>
                  {d.ubicacion}
                </td>
                <td class="px-4 py-3">
                  {d.evidence_path ? (
                    <a
                      href={`/api/admin/denuncias/download?id=${encodeURIComponent(d.id)}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="rounded-full border border-emerald-400/30 px-3 py-1 text-xs font-semibold text-emerald-200 transition-colors hover:bg-emerald-400/10"
                    >
                      Descargar
                    </a>
                  ) : (
                    <span class="text-white/45">—</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>
</AdminLayout>
