---
import { getAuthenticatedAdmin } from "../../lib/server/admin-auth";
import { isSupabaseConfigured } from "../../lib/server/supabase";

const session = await getAuthenticatedAdmin(Astro.cookies);

if (session.user) {
  return Astro.redirect("/admin");
}

const error = Astro.url.searchParams.get("error");
const errorMessage =
  error === "config"
    ? "Configura primero las variables de Supabase."
    : error === "acceso"
      ? "Ese usuario no esta autorizado para entrar al panel."
    : error === "credenciales"
      ? "Correo o contrasena invalidos."
      : "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ingreso Admin | Radio News Online</title>
  </head>
  <body class="min-h-screen bg-[#041d3d] text-white">
    <main class="mx-auto flex min-h-screen max-w-md items-center px-4 py-10">
      <section class="w-full rounded-[28px] border border-white/10 bg-white/5 p-8 shadow-[0_30px_80px_rgba(0,0,0,0.22)] backdrop-blur-sm">
        <p class="text-xs uppercase tracking-[0.24em] text-white/60">Panel de noticias</p>
        <h1 class="mt-4 font-newsreader text-4xl text-white">Ingreso admin</h1>
        <p class="mt-3 text-sm leading-6 text-white/70">
          Accede con el usuario creado en Supabase Auth para publicar y editar noticias.
        </p>

        {!isSupabaseConfigured() && (
          <div class="mt-6 rounded-2xl border border-amber-400/25 bg-amber-400/10 p-4 text-sm text-amber-100">
            Faltan variables de entorno de Supabase. El panel no podra iniciar sesion hasta configurarlas.
          </div>
        )}

        {errorMessage && (
          <div class="mt-6 rounded-2xl border border-red-400/25 bg-red-400/10 p-4 text-sm text-red-100">
            {errorMessage}
          </div>
        )}

        <form method="POST" action="/api/admin/login" class="mt-8 space-y-5">
          <label class="block">
            <span class="mb-2 block text-sm text-white/75">Correo</span>
            <input
              type="email"
              name="email"
              class="w-full rounded-2xl border border-white/10 bg-[#071a34] px-4 py-3 text-white outline-none transition-colors focus:border-[#a62b2b]"
              placeholder="admin@cliente.com"
              required
            />
          </label>

          <label class="block">
            <span class="mb-2 block text-sm text-white/75">Contrasena</span>
            <input
              type="password"
              name="password"
              class="w-full rounded-2xl border border-white/10 bg-[#071a34] px-4 py-3 text-white outline-none transition-colors focus:border-[#a62b2b]"
              placeholder="********"
              required
            />
          </label>

          <button
            type="submit"
            class="w-full rounded-2xl bg-[#a62b2b] px-4 py-3 font-semibold text-white transition-colors hover:bg-[#8f2424]"
          >
            Entrar al panel
          </button>
        </form>
      </section>
    </main>
  </body>
</html>
