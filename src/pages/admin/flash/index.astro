---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getAuthenticatedAdmin } from "../../../lib/server/admin-auth";
import { flashArticleHref } from "../../../lib/site-content";
import { listAdminFlashSlides, type FlashSlideRecord } from "../../../lib/server/site-cms";
import { isSupabaseConfigured } from "../../../lib/server/supabase";

const session = await getAuthenticatedAdmin(Astro.cookies);

if (!session.user) {
  return Astro.redirect("/admin/login");
}

if (!isSupabaseConfigured()) {
  return Astro.redirect("/admin/login?error=config");
}

let slides: FlashSlideRecord[] = [];
try {
  slides = await listAdminFlashSlides();
} catch {
  slides = [];
}
const error = Astro.url.searchParams.get("error");
const deleted = Astro.url.searchParams.get("deleted");
---

<AdminLayout title="Flash informativo" userEmail={session.user.email ?? undefined}>
  <section class="rounded-[28px] border border-white/10 bg-white/5 p-5 backdrop-blur-sm">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-3">
      <p class="text-sm text-white/70">Diapositivas del carrusel de portada (solo publicadas se muestran en la web).</p>
      <a
        href="/admin/flash/nueva"
        class="inline-flex rounded-full bg-[#a62b2b] px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#8f2424]"
      >
        Nueva diapositiva
      </a>
    </div>

    {error === "delete" && (
      <div class="mb-4 rounded-2xl border border-red-400/25 bg-red-400/10 p-4 text-sm text-red-100">No se pudo eliminar la diapositiva.</div>
    )}
    {error === "id" && (
      <div class="mb-4 rounded-2xl border border-red-400/25 bg-red-400/10 p-4 text-sm text-red-100">Solicitud invalida.</div>
    )}
    {deleted && (
      <div class="mb-4 rounded-2xl border border-emerald-400/25 bg-emerald-400/10 p-4 text-sm text-emerald-100">Diapositiva eliminada.</div>
    )}

    {slides.length === 0 ? (
      <div class="rounded-[22px] border border-dashed border-white/15 bg-[#06172f] p-8 text-center">
        <h2 class="font-newsreader text-2xl text-white">No hay diapositivas</h2>
        <p class="mt-3 text-sm text-white/70">Crea la primera entrada para el flash informativo.</p>
        <a
          href="/admin/flash/nueva"
          class="mt-5 inline-flex rounded-full bg-[#a62b2b] px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-[#8f2424]"
        >
          Nueva diapositiva
        </a>
      </div>
    ) : (
      <div class="overflow-hidden rounded-[22px] border border-white/10">
        <table class="min-w-full divide-y divide-white/10 text-left">
          <thead class="bg-white/5 text-xs uppercase tracking-[0.18em] text-white/60">
            <tr>
              <th class="px-5 py-4">Orden</th>
              <th class="px-5 py-4">Titulo</th>
              <th class="px-5 py-4">Estado</th>
              <th class="px-5 py-4">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/10 bg-[#06172f]">
            {slides.map((s) => (
              <tr>
                <td class="px-5 py-4 text-sm text-white/80">{s.sort_order}</td>
                <td class="px-5 py-4">
                  <div class="font-newsreader text-lg text-white">{s.title}</div>
                  <div class="mt-1 text-xs uppercase tracking-[0.14em] text-white/45">{s.category}</div>
                </td>
                <td class="px-5 py-4">
                  <span
                    class={`rounded-full px-3 py-1 text-xs uppercase tracking-[0.18em] ${s.status === "published" ? "bg-emerald-400/15 text-emerald-200" : "bg-amber-400/15 text-amber-100"}`}
                  >
                    {s.status}
                  </span>
                </td>
                <td class="px-5 py-4">
                  <div class="flex flex-wrap gap-2">
                    {s.status === "published" && s.image_url && (
                      <a
                        href={flashArticleHref(s.id)}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="rounded-full border border-emerald-400/30 px-4 py-2 text-sm text-emerald-200 transition-colors hover:bg-emerald-400/10"
                      >
                        Ver en sitio
                      </a>
                    )}
                    <a
                      href={`/admin/flash/${s.id}`}
                      class="rounded-full border border-white/15 px-4 py-2 text-sm text-white/85 transition-colors hover:bg-white/10"
                    >
                      Editar
                    </a>
                    <form method="POST" action="/api/admin/flash/delete" class="inline">
                      <input type="hidden" name="id" value={s.id} />
                      <button
                        type="submit"
                        class="rounded-full border border-red-400/30 px-4 py-2 text-sm text-red-200 transition-colors hover:bg-red-400/10"
                        onclick="return confirm('Eliminar esta diapositiva?');"
                      >
                        Eliminar
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>
</AdminLayout>
